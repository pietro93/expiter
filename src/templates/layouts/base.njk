<!DOCTYPE html>
<html lang="{{ lang | default('en') }}">
<head>
<meta charset="utf-8">
<link rel="canonical" href="{{ canonicalUrl }}"/>
<link rel="alternate" hreflang="en" href="{{ canonicalUrl }}" />
<link rel="alternate" hreflang="it" href="{{ hreflangIt }}" />
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ seoTitle }}</title>
<meta name="description" content="{{ seoDescription }}" />
<meta name="keywords" content="{{ seoKeywords }}" />
<meta property="og:title" content="{{ seoTitle }}" />
<meta property="og:description" content="{{ seoDescription }}" />
<meta property="og:image" content="{{ heroImage }}" />
<link rel="icon" type="image/x-icon" href="https://expiter.com/img/expiter-favicon.ico">

<!-- Bootstrap 5 + Icons -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

<!-- Deferred scripts -->
<script src="https://expiter.com/jquery3.6.0.js" defer></script>
<script type="text/json" src="https://expiter.com/dataset.json"></script>
<script src="https://expiter.com/script.js" defer></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>

<link rel="stylesheet" href="/style-v2.css">

</head>

<body>

<a class="visually-hidden-focusable" href="#main-content">Skip to content</a>

<!-- Clean Bootstrap navbar -->
<nav class="navbar navbar-expand-lg site-navbar sticky-top">
  <div class="container">
    <a class="navbar-brand d-flex align-items-center gap-2" href="/"><img src="/img/expiter.png" alt="Expiter logo" height="28" style="width:auto">Italy Expats &amp; Nomads</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#main-nav" aria-controls="main-nav" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="main-nav">
      <ul class="navbar-nav ms-auto">
        <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
        <li class="nav-item"><a class="nav-link" href="/provinces/">Provinces</a></li>
        <li class="nav-item"><a class="nav-link" href="https://expiter.com/resources/">Resources</a></li>
        <li class="nav-item"><a class="nav-link" href="https://expiter.com/tools/codice-fiscale-generator/">Tools</a></li>
        <li class="nav-item"><a class="nav-link" href="https://expiter.com/blog/articles/">Blog</a></li>
        <li class="nav-item"><a class="nav-link" href="https://expiter.com/app/#About">About</a></li>
      </ul>
    </div>
  </div>
</nav>

<div class="container py-4" id="main-content">
  <div class="row g-4">

    <main class="col-12 col-lg-8 col-xl-9 order-1">

      {% block breadcrumb %}
      <nav aria-label="breadcrumb" class="breadcrumb-mini">
        <a href="/">Home</a>
        <span class="sep">/</span>
        {% block breadcrumbProvinces %}<a href="/provinces/">Provinces</a>{% endblock %}
        <span class="sep">/</span>
        <span>{{ eyebrow }}</span>
      </nav>
      {% endblock %}

      <h1 class="entry-title" data-toc-skip id="title">{{ pageTitle }}</h1>

      {% if toc %}
      <details class="toc-card" open>
        <summary>Table of Contents</summary>
        <nav>{{ toc | safe }}</nav>
      </details>
      {% endif %}

      {% if tabRows %}
      <section class="scorecard mb-4" aria-label="Province scorecard">
        <ul class="nav nav-tabs" role="tablist">
          {% block tabLabels %}
          <li class="nav-item" role="presentation">
            <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#panel-ql" type="button" role="tab">Quality of Life</button>
          </li>
          <li class="nav-item" role="presentation">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#panel-col" type="button" role="tab">Cost of Living</button>
          </li>
          <li class="nav-item" role="presentation">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#panel-dn" type="button" role="tab">Digital Nomads</button>
          </li>
          {% endblock %}
        </ul>
        <div class="tab-content">
          {% macro renderRow(r) %}
            <div class="score-row">
              <span class="label"><span class="emoji">{{ r.emoji }}</span>{{ r.label }}</span>
              {% if r.raw %}<span class="value raw">{{ r.raw }}</span>
              {% else %}<span class="value"><span class="tier-chip {{ r.tier }}">{{ r.text }}</span></span>{% endif %}
            </div>
          {% endmacro %}
          {% macro renderPane(paneId, rows, isFirst) %}
            <div class="tab-pane fade {% if isFirst %}show active{% endif %}" id="{{ paneId }}" role="tabpanel">
              <div class="row">
                {% set half = (rows | length / 2) | round(0, 'ceil') %}
                <div class="col-12 col-md-6">
                  {% for r in rows %}{% if loop.index0 < half %}{{ renderRow(r) }}{% endif %}{% endfor %}
                </div>
                <div class="col-12 col-md-6">
                  {% for r in rows %}{% if loop.index0 >= half %}{{ renderRow(r) }}{% endif %}{% endfor %}
                </div>
              </div>
            </div>
          {% endmacro %}
          {{ renderPane('panel-ql',  tabRows.qualityOfLife, true) }}
          {{ renderPane('panel-col', tabRows.costOfLiving,  false) }}
          {{ renderPane('panel-dn',  tabRows.digitalNomads, false) }}
        </div>
      </section>
      {% endif %}

      <article class="entry-content">
        {% block infoSections %}{% endblock %}
      </article>

    </main>

    <aside class="col-12 col-lg-4 col-xl-3 order-2 sidebar-primary" aria-label="Sidebar">
      {{ sidebar | safe }}
    </aside>

  </div>
</div>

<footer class="site-footer text-center">
  <div class="container">© Expiter. Data for informational purposes only.</div>
</footer>

</body>
</html>
