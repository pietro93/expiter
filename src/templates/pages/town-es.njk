{% extends "layouts/base-es.njk" %}

{% block breadcrumbProvinces %}<a href="/es/provincia/">Provincias</a> <span class="sep">/</span> <a href="{{ provinceUrl }}">{{ provinceName }}</a>{% endblock %}

{% block infoSections %}
<section id="Info-Sheet">
  <h2>Ficha Informativa</h2>
  <div class="table-responsive">
    <table class="table info-table">
      <tbody>
        <tr><th>Nombre</th><td>{{ townName }}</td></tr>
        <tr><th>Provincia</th><td><a href="{{ provinceUrl }}">{{ provinceName }}</a></td></tr>
        <tr><th>Región</th><td>{{ regionName }}</td></tr>
        <tr><th>Población</th><td>{{ population }}</td></tr>
        <tr><th>Densidad</th><td>{{ density }} hab/km²</td></tr>
        <tr><th>Altitud</th><td>{{ altitude }} m</td></tr>
        <tr><th>Zona Climática</th><td>{{ climateZone }}</td></tr>
      </tbody>
    </table>
  </div>
</section>

<section id="Overview"><h2>Sobre {{ townName }}</h2><div id="overview">{{ intro | safe }}</div></section>

<section id="Climate"><h2>Clima</h2><div id="climate">{{ climate | safe }}</div></section>

<section id="Map"><h2>Mapa de {{ townName }}</h2><div id="map">{{ map | safe }}</div></section>

<section id="Tours"><h2>Experiencias y tours cerca de {{ townName }}</h2><div id="getyourguide">{{ getyourguide | safe }}</div></section>

<section id="Hotels"><h2>Hoteles y opciones de viaje en {{ townName }}</h2><div id="expedia">{{ expedia | safe }}</div></section>

<section id="Nearby"><h2>Municipios en la Provincia de {{ provinceName }}</h2><div id="nearby">{{ nearby | safe }}</div></section>

<section id="Related"><h2>Provincias Cercanas</h2><div id="related">{{ related | safe }}</div></section>

<div id="disclaimer-block">{{ disclaimer | safe }}</div>
{% endblock %}
