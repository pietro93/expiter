{% extends "layouts/base-it.njk" %}

{% block breadcrumbProvinces %}<a href="/it/province/">Province</a> <span class="sep">/</span> <a href="{{ provinceUrl }}">{{ provinceName }}</a>{% endblock %}

{% block infoSections %}
<section id="Info-Sheet">
  <h2>Scheda Informativa</h2>
  <div class="table-responsive">
    <table class="table info-table">
      <tbody>
        <tr><th>Nome</th><td>{{ townName }}</td></tr>
        <tr><th>Provincia</th><td><a href="{{ provinceUrl }}">{{ provinceName }}</a></td></tr>
        <tr><th>Regione</th><td>{{ regionName }}</td></tr>
        <tr><th>Popolazione</th><td>{{ population }}</td></tr>
        <tr><th>Densità</th><td>{{ density }} ab/km²</td></tr>
        <tr><th>Altitudine</th><td>{{ altitude }} m</td></tr>
        <tr><th>Zona Climatica</th><td>{{ climateZone }}</td></tr>
      </tbody>
    </table>
  </div>
</section>

<section id="Overview"><h2>Su {{ townName }}</h2><div id="overview">{{ intro | safe }}</div></section>

<section id="Climate"><h2>Clima</h2><div id="climate">{{ climate | safe }}</div></section>

<section id="Map"><h2>Mappa di {{ townName }}</h2><div id="map">{{ map | safe }}</div></section>

<section id="Tours"><h2>Esperienze e tour vicino a {{ townName }}</h2><div id="getyourguide">{{ getyourguide | safe }}</div></section>

<section id="Hotels"><h2>Hotel e opzioni di viaggio a {{ townName }}</h2><div id="expedia">{{ expedia | safe }}</div></section>

<section id="Nearby"><h2>Comuni nella Provincia di {{ provinceName }}</h2><div id="nearby">{{ nearby | safe }}</div></section>

<section id="Related"><h2>Province Vicine</h2><div id="related">{{ related | safe }}</div></section>

<div id="disclaimer-block">{{ disclaimer | safe }}</div>
{% endblock %}
