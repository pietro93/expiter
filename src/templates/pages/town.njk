{% extends "layouts/base.njk" %}

{% block breadcrumbProvinces %}<a href="/provinces/">Provinces</a> <span class="sep">/</span> <a href="{{ provinceUrl }}">{{ provinceName }}</a>{% endblock %}

{% block infoSections %}
<section id="Info-Sheet">
  <h2>Info Sheet</h2>
  <div class="table-responsive">
    <table class="table info-table">
      <tbody>
        <tr><th>Name</th><td>{{ townName }}</td></tr>
        <tr><th>Province</th><td><a href="{{ provinceUrl }}">{{ provinceName }}</a></td></tr>
        <tr><th>Region</th><td>{{ regionName }}</td></tr>
        <tr><th>Population</th><td>{{ population }}</td></tr>
        <tr><th>Density</th><td>{{ density }} pp/km²</td></tr>
        <tr><th>Altitude</th><td>{{ altitude }} m</td></tr>
        <tr><th>Climate Zone</th><td>{{ climateZone }}</td></tr>
      </tbody>
    </table>
  </div>
</section>

<section id="Overview"><h2>About {{ townName }}</h2><div id="overview">{{ intro | safe }}</div></section>

<section id="Climate"><h2>Climate</h2><div id="climate">{{ climate | safe }}</div></section>

<section id="Map"><h2>Map of {{ townName }}</h2><div id="map">{{ map | safe }}</div></section>

<section id="Tours"><h2>Experiences and tours near {{ townName }}</h2><div id="getyourguide">{{ getyourguide | safe }}</div></section>

<section id="Hotels"><h2>Hotels and travel options in {{ townName }}</h2><div id="expedia">{{ expedia | safe }}</div></section>

<section id="Nearby"><h2>Towns in the Province of {{ provinceName }}</h2><div id="nearby">{{ nearby | safe }}</div></section>

<section id="Related"><h2>Provinces Nearby</h2><div id="related">{{ related | safe }}</div></section>

<div id="disclaimer-block">{{ disclaimer | safe }}</div>
{% endblock %}
