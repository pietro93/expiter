<section class="scorecard" aria-label="Province scorecard">
  <input type="radio" id="tab-ql"  name="sc-tab" checked>
  <input type="radio" id="tab-col" name="sc-tab">
  <input type="radio" id="tab-dn"  name="sc-tab">

  <div class="tab-strip">
    <label for="tab-ql">Quality of Life</label>
    <label for="tab-col">Cost of Living</label>
    <label for="tab-dn">Digital Nomads</label>
  </div>

  <div class="tab-bodies">
    <div id="panel-ql" class="tab-panel">
      <div class="score-grid">
        <div>{{ tab1col1 | safe }}</div>
        <div>{{ tab1col2 | safe }}</div>
      </div>
    </div>
    <div id="panel-col" class="tab-panel">
      <div class="score-grid">
        <div>{{ tab2col1 | safe }}</div>
        <div>{{ tab2col2 | safe }}</div>
      </div>
    </div>
    <div id="panel-dn" class="tab-panel">
      <div class="score-grid">
        <div>{{ tab3col1 | safe }}</div>
        <div>{{ tab3col2 | safe }}</div>
      </div>
    </div>
  </div>
</section>

<style>
/* Style the existing <p><ej>…</ej>Label: <score>…</score></p> rows as flex rows.
   The legacy content is preserved verbatim — we just restyle the <p> as a row. */
.score-grid > div > p {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 10px 0;
  margin: 0;
  border-bottom: 1px solid var(--c-border);
  font-size: 0.95rem;
  line-height: 1.4;
}
.score-grid > div > p:last-child { border-bottom: none; }
.score-grid > div > p > ej {
  font-style: normal;
  display: inline-block;
  width: 1.4em;
  text-align: center;
  margin-right: 6px;
  line-height: 1;
}
.score-grid > div > p > b { font-weight: 600; }
.score-grid > div > p > score { margin-left: auto; }
</style>
